@model StudentResultAppWithMVC.Models.DepartmentViewModel

@{
    ViewData["Title"] = "Edit Department";
}

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">

    <input asp-for="DepartmentId" type="hidden" />

    <div asp-validation-summary="ModelOnly"
         class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="DepartmentName"
               class="form-label"></label>

        <input asp-for="DepartmentName"
               class="form-control" />

        <span asp-validation-for="DepartmentName"
              class="text-danger"></span>
    </div>

    <button class="btn btn-primary"
            type="submit">
        Update
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>

