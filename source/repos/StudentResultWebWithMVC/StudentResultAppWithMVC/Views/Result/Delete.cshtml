@model StudentResultAppWithMVC.Models.Entity.Result

@{
    ViewData["Title"] = "Delete Result";
}

<h2>Delete Result</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this Result?
</div>

<dl class="row">

    <dt class="col-sm-3">
        Student Name
    </dt>

    <dd class="col-sm-9">
        @Model.student?.StudentName
    </dd>

    <dt class="col-sm-3">
        Physics
    </dt>

    <dd class="col-sm-9">
        @Model.PhysicsMark
    </dd>

    <dt class="col-sm-3">
        Chemistry
    </dt>

    <dd class="col-sm-9">
        @Model.ChemistryMark
    </dd>

    <dt class="col-sm-3">
        Math
    </dt>

    <dd class="col-sm-9">
        @Model.MathMark
    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden"
           asp-for="ResultId" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>
