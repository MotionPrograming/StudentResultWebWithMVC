@model SearchViewModel

@{
    ViewData["Title"] = "Search Students";
}

<h2>Search Students</h2>

<!-- Search and Filter Form -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="SearchQuery" class="form-label">Search by Name or ID</label>
                    <input type="text"
                           asp-for="SearchQuery"
                           placeholder="Enter student name or ID"
                           class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="DepartmentId" class="form-label">Filter by Department</label>
                    <select asp-for="DepartmentId"
                            asp-items="@(new SelectList(Model.Departments, "Value", "Text"))"
                            class="form-select">
                        <option value="">-- All Departments --</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="Age" class="form-label">Filter by Age</label>
                    <input type="number"
                           asp-for="Age"
                           placeholder="Enter age"
                           min="0"
                           class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="LetterGrade" class="form-label">Filter by Letter Grade</label>
                    <select asp-for="LetterGrade" class="form-select">
                        <option value="">-- All Grades --</option>
                        <option value="A+">A+</option>
                        <option value="A">A</option>
                        <option value="A-">A-</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                        <option value="F">F</option>
                    </select>
                </div>

                <div class="col-md-8 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        Clear Filters
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results Summary -->
<div class="mb-3">
    <p class="text-muted">
        Found <strong>@Model.Students.Count()</strong> student(s)
        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            <span>matching "@Model.SearchQuery"</span>
        }
    </p>
</div>

<!-- Students Table -->
@if (Model.Students.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Age</th>
                <th>Department</th>
                <th>Total Mark</th>
                <th>Average Mark</th>
                <th>Letter Grade</th>
                <th>CGPA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model.Students)
            {
                <tr>
                    <td>@student.StudentId</td>
                    <td>@student.StudentName</td>
                    <td>@student.StudentAge</td>
                    <td>@student.department?.DepartmentName</td>
                    <td>@student.TotalMark.ToString("F2")</td>
                    <td>@student.AverageMark.ToString("F2")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(student.LetterGrade))
                        {
                            <span class="badge bg-info">@student.LetterGrade</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>@student.CGPA.ToString("F2")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No students found matching your search criteria.
    </div>
}
